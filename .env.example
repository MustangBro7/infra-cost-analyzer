# Optional local scanner root. Defaults to the parent folder of this project.
REPO_SCAN_ROOT=..

# MotherDuck analytics. Local development should use the dedicated
# infra_cost_analyzer_dev database. Production uses the ANALYTICS_DB Hyperdrive
# binding; this direct URL is also used by migration and backfill scripts.
MOTHERDUCK_DATABASE_URL=
ANALYTICS_ENABLED=true
ANALYTICS_READS_ENABLED=true
ANALYTICS_SEED_USER_ID=

# Required by analytics:backfill:d1 when reading the production D1 REST API.
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=

# Clerk authentication (Google sign-in + email). Auth is owned by Clerk.
# Local dev keys are written to .env.local by `npx clerk init`. In production the
# publishable key + sign-in URLs live in wrangler.jsonc `vars`, and the secret key
# is a Worker secret: `npx wrangler secret put CLERK_SECRET_KEY`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
APP_URL=

# Optional GitHub API credentials for future hosted scans.
GITHUB_APP_ID=4042284
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Auto-connect credentials. When set, sign-in connects these providers
# automatically (zero clicks). In production set them as Workers secrets:
#   npx wrangler secret put VERCEL_TOKEN
#   npx wrangler secret put CLOUDFLARE_PROVIDER_API_TOKEN
#   npx wrangler secret put GCP_SERVICE_ACCOUNT_KEY   (raw or base64 key JSON)
# Optional: VERCEL_TEAM_ID / VERCEL_TEAM_SLUG, GCP_BILLING_EXPORT_TABLE
# (the billing export table is auto-discovered when not set).
VERCEL_TOKEN=
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=
VERCEL_OAUTH_REDIRECT_URI=http://localhost:3002/api/vercel/oauth/callback
# AWS one-click connect: customers launch infra/aws-cost-readonly.cfn.yaml which
# creates a read-only role trusting THIS SaaS principal (an IAM user with only
# sts:AssumeRole), gated by a per-connection ExternalId. The app stores just the
# role ARN + external id and assumes the role on demand — no customer keys stored.
# Set these as Worker secrets in production (npx wrangler secret put ...).
AWS_SAAS_ACCESS_KEY_ID=
AWS_SAAS_SECRET_ACCESS_KEY=
AWS_SAAS_REGION=us-east-1
# 12-digit account id of the SaaS principal; customer roles trust this account.
# Surfaced to the companion CLI via /api/cli/aws/params so it can build the trust policy.
AWS_SAAS_ACCOUNT_ID=
# AWS is per-user and NOT auto-connected from env: each user connects their own
# account from the UI (read-only IAM role, or access keys as an advanced fallback).
# Cost Explorer (ce:GetCostAndUsage) bills $0.01/request and is opt-in;
# freetier:GetFreeTierUsage is free.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
CLOUDFLARE_PROVIDER_API_TOKEN=
DIGITALOCEAN_TOKEN=
