{
  "name": "infra-cost-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Repository-aware infrastructure cost analyzer for GitHub projects.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "verify": "npm run check && npm run test && npm run build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.3",
    "@opennextjs/cloudflare": "^1.19.11",
    "lucide-react": "^0.511.0",
    "next": "^16.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
